# Keep the Docker build context small and secret-free (TB-103).
# Everything the build needs is restored from the .csproj files; source is copied fresh.

**/bin/
**/obj/
**/.vs/
.git/
.gitignore
.dockerignore

# Local secrets / environment — must never enter an image layer.
.env
.env.*
**/appsettings.Development.json
**/appsettings.*.Development.json

# Editor / OS noise
**/.vscode/
**/*.user
**/.DS_Store

# Docs & test artifacts not needed to build the server
**/TestResults/
*.md

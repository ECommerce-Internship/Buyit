{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=BuyitDb;Username=postgres;Password=<your-password>",
    "Redis": "localhost:6379,abortConnect=false",
    "AzureBlobStorage": "DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-account-key>;EndpointSuffix=core.windows.net"
  },
  "Jwt": {
    "Secret": "<generate-a-base64-encoded-256-bit-secret>",
    "Issuer": "BuyitApi",
    "Audience": "BuyitClients",
    "ExpiryMinutes": 15
  },
  "Authentication": {
    "Google": {
      "ClientId": "<your-google-oauth-client-id>",
      "ClientSecret": "<your-google-oauth-client-secret>",
      "RedirectUri": "https://localhost:7001/api/auth/callback/google"
    }
  }
}
